<Window x:Class="WpfApp2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp2"
        mc:Ignorable="d"
        Title="Orovsi Nóbeldijasok" Height="400" Width="280">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="150"/>
        </Grid.ColumnDefinitions>
        <!-- Év -->
        <Label Grid.Row="0" Grid.Column="0" Content="ÉV:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="YearTextBox" Margin="5,5,64,5"/>

       <!-- Név -->
        <Label Grid.Row="1" Grid.Column="0" Content="Név:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="NameTextBox" Margin="5,5,20,5"/>
     <!-- SZ/H -->
        <Label Grid.Row="2" Grid.Column="0" Content="SZ/H:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="CountryTextBox" Margin="5,5,64,5"/>
      <!-- ország -->
        <Label Grid.Row="3" Grid.Column="0" Content="Ország" VerticalAlignment="Center"/>
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="ország" VerticalAlignment="Center"/>


        <Button Grid.Row="5" Grid.ColumnSpan="2" Width="80" Height="30" HorizontalAlignment="Center" Content="Hozzáadás" Click="AddButton_Click"/>

    </Grid>
</Window>
